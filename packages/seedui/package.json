{
  "name": "@juliensouki/seedui",
  "version": "0.0.1",
  "description": "A React component library and design system.",
  "license": "MIT",
  "author": "Julien Souki-Léon <julien.soukileon@gmail.com>",
  "homepage": "https://seedui.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/juliensouki/seedui.git",
    "directory": "packages/seedui"
  },
  "bugs": {
    "url": "https://github.com/juliensouki/seedui/issues"
  },
  "keywords": [
    "react",
    "component-library",
    "design-system",
    "ui",
    "ui-components",
    "styled-components",
    "typescript",
    "dark-mode",
    "theme"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./sc": {
      "types": "./dist/sc.d.ts",
      "import": "./dist/sc.js"
    }
  },
  "typesVersions": {
    "*": {
      "sc": [
        "dist/sc.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --noEmit && vite build",
    "dev": "vite build --watch",
    "lint": "eslint ./src --report-unused-disable-directives"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "styled-components": "^6.1.0"
  },
  "resolutions": {
    "styled-components": "^6"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^18.2.38",
    "@types/react-dom": "^18.2.15",
    "@vitejs/plugin-react": "^4.2.0",
    "typescript": "^5.8.2",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.6.3"
  },
  "dependencies": {
    "@ctrl/tinycolor": "^4.1.0"
  }
}
