{
  "name": "@seedui-react/seedui",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.1.33",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./sc": {
      "types": "./dist/sc.d.ts",
      "import": "./dist/sc.js"
    }
  },
  "typesVersions": {
    "*": {
      "sc": [
        "dist/sc.d.ts"
      ]
    }
  },
  "scripts": {
    "build": "tsc --noEmit && vite build",
    "dev": "vite build --watch",
    "lint": "eslint ./src --report-unused-disable-directives"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "styled-components": "^6.1.15"
  },
  "resolutions": {
    "styled-components": "^6"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^18.2.38",
    "@types/react-dom": "^18.2.15",
    "@vitejs/plugin-react": "^4.2.0",
    "typescript": "^5.8.2",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.6.3"
  },
  "dependencies": {
    "@ctrl/tinycolor": "^4.1.0"
  }
}
