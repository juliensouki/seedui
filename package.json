{
  "description": "Seed UI codebase",
  "license": "UNLICENSED",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "resolutions": {
    "@seedui-react/seedui": "workspace:packages/seedui"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@stylistic/eslint-plugin-js": "^4.2.0",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^6.10.0",
    "@yarnpkg/plugin-workspace-tools": "^4.0.0-rc.25",
    "eslint": "^9.22.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "jiti": "^2.4.2",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1"
  },
  "scripts": {
    "lint": "yarn workspaces foreach -A run lint",
    "build:app:sandbox": "yarn workspace @seedui-react/sandbox run build",
    "dev:app:sandbox": "yarn workspace @seedui-react/sandbox run dev",
    "build:app:demo": "yarn workspace @seedui-react/demo run build",
    "dev:app:demo": "yarn workspace @seedui-react/demo run dev",
    "build:package:seedui": "yarn workspace @seedui-react/seedui run build",
    "dev:package:seedui": "yarn workspace @seedui-react/seedui run dev"
  },
  "packageManager": "yarn@3.1.1"
}
