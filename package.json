{
  "name": "@seedui/seed-ui",
  "description": "Seed-ui codebase",
  "license": "UNLICENSED",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "resolutions": {
    "@seedui/seedui": "workspace:packages/seedui"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.3",
    "@testing-library/react": "^14.0.0",
    "@types/jest": "^29.5.4",
    "@yarnpkg/plugin-workspace-tools": "^4.0.0-rc.25",
    "jest": "^29.6.4",
    "jest-environment-jsdom": "^29.6.4",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.1"
  },
  "scripts": {
    "lint": "yarn workspaces foreach -A run lint",
    "test": "jest",
    "build:app:seedui.dev": "yarn workspace @seedui/seedui.dev run build",
    "dev:app:seedui.dev": "yarn workspace @seedui/seedui.dev run dev",
    "dev:app:sandbox": "yarn workspace @seedui/sandbox run dev",
    "build:package:seedui": "yarn workspace @seedui/seedui run build",
    "dev:package:seedui": "yarn workspace @seedui/seedui run dev"
  },
  "packageManager": "yarn@3.1.1"
}
